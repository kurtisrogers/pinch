# Pinch local env (copy to .env and fill in after Supabase setup)
# Without these, billing is disabled and all tools run without sign-in.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe Payment Link or Checkout URL for Pro upgrades (optional)
VITE_STRIPE_PRO_CHECKOUT_URL=https://buy.stripe.com/your-link
